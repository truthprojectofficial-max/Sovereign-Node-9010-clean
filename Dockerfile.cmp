FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=development

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

# Component registry — introspects src/, maintains hot-reload state
# Serves metadata on :8001 for client-side discovery
EXPOSE 8001

CMD ["node", "-e", "\
  const express = require('express'); \
  const fs = require('fs'); \
  const path = require('path'); \
  const app = express(); \
  \
  const SRC_DIR = '/app/src'; \
  \
  function scanComponents() { \
    const comps = {}; \
    if (fs.existsSync(SRC_DIR)) { \
      const files = fs.readdirSync(SRC_DIR); \
      files.forEach(f => { \
        if (f.endsWith('.ts') || f.endsWith('.tsx')) { \
          comps[f] = { \
            name: f, \
            path: path.join(SRC_DIR, f), \
            size: fs.statSync(path.join(SRC_DIR, f)).size, \
            modified: new Date(fs.statSync(path.join(SRC_DIR, f)).mtime).toISOString() \
          }; \
        } \
      }); \
    } \
    return comps; \
  } \
  \
  app.get('/health', (req, res) => { \
    res.json({ status: 'operational', service: 'cmp', port: 8001 }); \
  }); \
  \
  app.get('/components', (req, res) => { \
    res.json({ components: scanComponents() }); \
  }); \
  \
  app.listen(8001, () => { \
    console.log('Component Registry (CMP) listening on port 8001'); \
  }); \
"]
